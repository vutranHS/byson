    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "mongodb": "^7.1.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
